<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="404.0" prefWidth="541.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AltaProductoController">
    <children>
        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="DODGERBLUE" height="95.0" stroke="BLACK" strokeType="INSIDE" width="541.0" />
        <Label layoutX="110.0" layoutY="26.0" text="CREAR PRODUCTO💡" textFill="#f2f2f2">
            <font>
                <Font name="Roboto Mono for Powerline" size="36.0" />
            </font>
        </Label>

        <Button fx:id="btnRegresar" layoutX="150.0" layoutY="333.0" mnemonicParsing="false" onAction="#regresarMenuAdmin" prefHeight="39.0" prefWidth="111.0" style="-fx-background-color: #636363;" text="Regresar" textFill="WHITE" underline="true" />
        <Button fx:id="btnCrearProducto" layoutX="298.0" layoutY="333.0" mnemonicParsing="false" onAction="#crearProducto" prefHeight="39.0" prefWidth="111.0" style="-fx-background-color: #4CAF50;" text="Alta Producto" textFill="WHITE" underline="true" />

        <Label fx:id="lblNombreProducto" layoutX="151.0" layoutY="125.0" prefHeight="26.0" prefWidth="58.0" text="Nombre" />
        <TextField fx:id="txtNombreProducto" layoutX="246.0" layoutY="125.0" prefHeight="26.0" prefWidth="162.0" promptText="nombre del producto" />

        <Label fx:id="lblPrecioCompra" layoutX="149.0" layoutY="167.0" prefHeight="17.0" prefWidth="90.0" text="Precio Compra" />
        <TextField fx:id="txtPrecioCompra" layoutX="248.0" layoutY="162.0" prefHeight="26.0" prefWidth="162.0" promptText="0.00" />

        <Label fx:id="lblPrecioVenta" layoutX="149.0" layoutY="202.0" prefHeight="17.0" prefWidth="90.0" text="Precio Venta" />
        <TextField fx:id="txtPrecioVenta" layoutX="248.0" layoutY="197.0" prefHeight="26.0" prefWidth="162.0" promptText="0.00" />

        <Label fx:id="lblExistencias" layoutX="150.0" layoutY="237.0" prefHeight="17.0" prefWidth="70.0" text="Existencias" />
        <TextField fx:id="txtExistencias" layoutX="248.0" layoutY="232.0" prefHeight="26.0" prefWidth="162.0" promptText="cantidad" />

        <Label fx:id="lblNivelReorden" layoutX="149.0" layoutY="273.0" prefHeight="17.0" prefWidth="90.0" text="Nivel Reorden" />
        <TextField fx:id="txtNivelReorden" layoutX="248.0" layoutY="268.0" prefHeight="26.0" prefWidth="162.0" promptText="cantidad mínima" />

    </children>
</AnchorPane>
